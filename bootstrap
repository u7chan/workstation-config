#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
readonly ROOT_DIR

usage() {
  cat <<'EOF'
Usage: ./bootstrap [base|personal]

Profiles:
  personal  Base configuration plus personal roles (default)
  base      Common configuration only
EOF
}

die() {
  printf 'bootstrap: %s\n' "$*" >&2
  exit 1
}

if [[ ${1:-} == "-h" || ${1:-} == "--help" ]]; then
  usage
  exit 0
fi

(( $# <= 1 )) || die "expected at most one profile argument"
readonly PROFILE="${1:-personal}"
[[ $PROFILE == "base" || $PROFILE == "personal" ]] || die "profile must be 'base' or 'personal'"

[[ ${EUID} -ne 0 ]] || die "run as a regular user, not root"
[[ -r /etc/os-release ]] || die "cannot read /etc/os-release"

# shellcheck disable=SC1091
source /etc/os-release
[[ ${ID:-} == "ubuntu" && ${VERSION_ID:-} == "26.04" ]] || die "Ubuntu 26.04 is required"
grep -qi 'microsoft-standard-WSL2' /proc/sys/kernel/osrelease || die "WSL2 is required"
MACHINE_ARCH="$(uname -m)"
readonly MACHINE_ARCH
[[ $MACHINE_ARCH == "x86_64" ]] || die "x86_64 is required (detected: $MACHINE_ARCH)"
command -v sudo >/dev/null 2>&1 || die "sudo is required"

printf '==> Validating sudo access\n'
# Ubuntu 26.04 ships sudo-rs as the default sudo implementation, which does not
# handle Ansible's become password prompt correctly. Use the compatibility
# wrapper when it is available and the active sudo is sudo-rs.
SUDO_EXE=""
if [[ -x /usr/bin/sudo.ws ]] && sudo --version 2>/dev/null | grep -q '^sudo-rs'; then
  SUDO_EXE="/usr/bin/sudo.ws"
fi

# When sudo-rs is the default and we use sudo.ws for become, the credential
# cache created by sudo.ws -v does not reliably survive into Ansible's become
# subprocess. Always ask for become password in that case so Ansible can prompt
# the user directly. For plain sudo, detect password requirements and refresh
# the credential cache for direct sudo calls (apt, etc.).
ASK_PASS=""
if [[ -n $SUDO_EXE ]]; then
  ASK_PASS="True"
elif ! "${SUDO_EXE:-sudo}" -n true 2>/dev/null; then
  ASK_PASS="True"
fi
"${SUDO_EXE:-sudo}" -v

if ! command -v ansible-playbook >/dev/null 2>&1; then
  printf '==> Installing Ubuntu ansible-core\n'
  "${SUDO_EXE:-sudo}" env DEBIAN_FRONTEND=noninteractive apt-get update
  "${SUDO_EXE:-sudo}" env DEBIAN_FRONTEND=noninteractive \
    apt-get install --yes --no-install-recommends ansible-core
fi

printf '==> Applying Ansible profile: %s\n' "$PROFILE"
ansible_become_vars=()
[[ -n $SUDO_EXE ]] && ansible_become_vars+=(ANSIBLE_BECOME_EXE="$SUDO_EXE")
[[ -n $ASK_PASS ]] && ansible_become_vars+=(ANSIBLE_BECOME_ASK_PASS="$ASK_PASS")

env \
  ANSIBLE_CONFIG="$ROOT_DIR/ansible/ansible.cfg" \
  "${ansible_become_vars[@]}" \
  ansible-playbook \
  --inventory "$ROOT_DIR/ansible/inventory/localhost.yml" \
  --extra-vars "workstation_profile=$PROFILE" \
  "$ROOT_DIR/ansible/playbook.yml"

printf '==> Applying chezmoi source\n'
"$HOME/.local/bin/chezmoi" apply --source "$ROOT_DIR/home" --no-tty --force

printf '==> Trusting mise configuration\n'
"$HOME/.local/bin/mise" trust "$HOME/.config/mise/config.toml"

printf '==> Installing mise tools\n'
MISE_LOCKED=1 \
MISE_YES=1 \
  /usr/bin/flock "$HOME/.local/state/workstation-update/update.lock" \
    "$HOME/.local/bin/mise" install

printf '==> Bootstrap complete: %s\n' "$PROFILE"
