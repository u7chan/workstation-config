#!/usr/bin/env bash
set -euo pipefail

command -v python3 >/dev/null 2>&1 || {
  printf 'http-lan: python3 is not installed\n' >&2
  exit 1
}

host_ip=$(hostname -I 2>/dev/null | awk '{print $1}')
printf 'WARNING: serving the current directory on all network interfaces.\n' >&2
printf 'LAN URL: http://%s:8000/ (the port may differ if specified)\n' "${host_ip:-0.0.0.0}" >&2

python3 -u -m http.server "$@" --bind 0.0.0.0 2>&1 |
  sed -u \
    -e 's#Serving HTTP on 0\.0\.0\.0#Serving HTTP on all interfaces#' \
    -e "s#http://0\\.0\\.0\\.0:\\([0-9][0-9]*\\)/#http://${host_ip:-0.0.0.0}:\\1/#"
