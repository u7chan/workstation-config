#!/usr/bin/env bash
set -euo pipefail

HERDR_BIN="${HERDR_BIN:-herdr}"
readonly HERDR_BIN
readonly INTEGRATIONS=(codex claude opencode)

command -v "$HERDR_BIN" >/dev/null 2>&1 || {
  printf 'install-herdr-integrations: herdr is not available on PATH\n' >&2
  exit 1
}

# Herdr requires each agent's configuration directory to exist. Creating only
# the parents keeps all integration files under Herdr's ownership and supports
# an installed but not-yet-authenticated AI CLI.
mkdir -p "$HOME/.codex" "$HOME/.claude" "$HOME/.config/opencode"

for integration in "${INTEGRATIONS[@]}"; do
  "$HERDR_BIN" integration install "$integration"
done

status="$($HERDR_BIN integration status)"
printf '%s\n' "$status"

for integration in "${INTEGRATIONS[@]}"; do
  if ! grep -Eq "^${integration}: current \\(v[0-9]+\\) " <<<"$status"; then
    printf 'install-herdr-integrations: %s integration is not current\n' "$integration" >&2
    exit 1
  fi
done
